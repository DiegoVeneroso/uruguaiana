--- !tapi-tbd
tbd-version:     4
targets:         [ x86_64-ios-simulator, arm64-ios-simulator ]
flags:           [ not_app_extension_safe ]
install-name:    '@rpath/camera_avfoundation.framework/camera_avfoundation'
exports:
  - targets:         [ x86_64-ios-simulator, arm64-ios-simulator ]
    symbols:         [ _FLTCaptureSessionQueueSpecific, _FLTEnsureToRunOnMainQueue, 
                       _FLTGetAVCaptureFlashModeForFLTFlashMode, _FLTGetFLTExposureModeForString, 
                       _FLTGetFLTFlashModeForString, _FLTGetFLTFocusModeForString, 
                       _FLTGetFLTResolutionPresetForString, _FLTGetStringForFLTExposureMode, 
                       _FLTGetStringForFLTFocusMode, _FLTGetStringForUIDeviceOrientation, 
                       _FLTGetUIDeviceOrientationForString, _FLTGetVideoFormatFromString, 
                       _FLTRequestAudioPermissionWithCompletionHandler, _FLTRequestCameraPermissionWithCompletionHandler, 
                       _FLTRequestPermission, _camera_avfoundationVersionNumber, 
                       _camera_avfoundationVersionString, _errorMethod ]
    objc-classes:    [ CameraPlugin, FLTCam, FLTImageStreamHandler, FLTSavePhotoDelegate, 
                       FLTThreadSafeEventChannel, FLTThreadSafeFlutterResult, FLTThreadSafeMethodChannel, 
                       FLTThreadSafeTextureRegistry, PodsDummy_camera_avfoundation ]
...
