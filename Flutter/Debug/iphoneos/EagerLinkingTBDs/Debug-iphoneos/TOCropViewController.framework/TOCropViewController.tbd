--- !tapi-tbd
tbd-version:     4
targets:         [ arm64-ios ]
flags:           [ not_app_extension_safe ]
install-name:    '@rpath/TOCropViewController.framework/TOCropViewController'
exports:
  - targets:         [ arm64-ios ]
    symbols:         [ _TOCropViewControllerVersionNumber, _TOCropViewControllerVersionString ]
    objc-classes:    [ PodsDummy_TOCropViewController, TOActivityCroppedImageProvider, 
                       TOCropOverlayView, TOCropScrollView, TOCropToolbar, TOCropView, 
                       TOCropViewController, TOCropViewControllerTransitioning, TOCroppedImageAttributes ]
...
